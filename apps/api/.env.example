# Banco de dados
DATABASE_URL="postgresql://legislativo:legislativo_secret@localhost:5432/legislativo"

# Redis
REDIS_URL="redis://localhost:6379"

# Keycloak
KEYCLOAK_URL="http://localhost:8080"
KEYCLOAK_REALM="legislativo"
KEYCLOAK_CLIENT_ID="legislativo-api"
KEYCLOAK_ISSUER="http://localhost:8080/realms/legislativo"
KEYCLOAK_PUBLIC_KEY=""

# Camunda
CAMUNDA_URL="http://localhost:8085"
CAMUNDA_AUTH_TOKEN=""

# MinIO / S3
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="legislativo"
MINIO_SECRET_KEY="legislativo_secret_minio"
MINIO_BUCKET="legislativo-documentos"

# SMTP
SMTP_HOST="localhost"
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@camaramunicipal.gov.br"

# Servidor
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
